import React from 'react';

async function getAnime() {
  const res = await fetch('https://shikimori.one/api/animes?limit=10&order=popularity');
  return res.json();
}

export default async function Home() {
  const animes = await getAnime();

  return (
    <main style={{ backgroundColor: '#0f172a', color: 'white', minHeight: '100vh', padding: '40px 20px', fontFamily: 'sans-serif' }}>
      <header style={{ textAlign: 'center', marginBottom: '40px' }}>
        <h1 style={{ fontSize: '3rem', color: '#38bdf8' }}>ANIMEX</h1>
        <p style={{ color: '#94a3b8' }}>Daftar Anime Terpopuler Saat Ini</p>
      </header>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '20px', maxWidth: '1200px', margin: '0 auto' }}>
        {animes.map((anime: any) => (
          <div key={anime.id} style={{ backgroundColor: '#1e293b', borderRadius: '12px', overflow: 'hidden', border: '1px solid #334155' }}>
            <img 
              src={`https://shikimori.one${anime.image.original}`} 
              alt={anime.name} 
              style={{ width: '100%', height: '300px', objectFit: 'cover' }}
            />
            <div style={{ padding: '15px' }}>
              <h3 style={{ fontSize: '1rem', marginBottom: '10px' }}>{anime.russian || anime.name}</h3>
              <span style={{ backgroundColor: '#38bdf8', color: '#0f172a', padding: '4px 8px', borderRadius: '4px', fontSize: '0.8rem', fontWeight: 'bold' }}>
                Skor: {anime.score}
              </span>
            </div>
          </div>
        ))}
      </div>
    </main>
  );
}
